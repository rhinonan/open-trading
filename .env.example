# TikHub API 域名
# 中国大陆用户（被墙，需用备选域名）: https://api.tikhub.dev
# 海外用户（主域名）: https://api.tikhub.io
TIKHUB_BASE=https://api.tikhub.dev
TIKHUB_API_KEY=your-tikhub-api-key
# 启用本地文件缓存（避免重复请求 API，节省配额）
DOUYIN_CACHE_MODE=true
# 扫描截止日期：只拉取此日期之后发布的视频 (YYYY-MM-DD)
DOUYIN_SCAN_CUTOFF_DATE=2026-06-01
NEWAPI_BASE_URL=https://newapi.tdance.cc/v1
NEWAPI_API_KEY=sk-your-key-here
# 讯飞语音识别 API（语音听写 + 语音转写）
# 控制台：https://console.xfyun.cn/services/iat
ASR_API_KEY=
ASR_API_SECRET=
# 视频 / 音频文件保留天数（scripts/cleanup.ts 使用）
VIDEO_RETENTION_DAYS=7
# 数据根目录（业务库 / 缓存 / 音视频 / mastra.db）。不设则默认 <项目>/data
# DATA_ROOT=
